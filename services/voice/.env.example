# Path to piper.exe binary
PIPER_BINARY=C:/tools/piper/piper.exe

# Path to the .onnx voice model
# Models: https://github.com/rhasspy/piper/blob/master/VOICES.md
PIPER_MODEL_PATH=C:/tools/piper/models/en_GB-semaine-medium/en_GB-semaine-medium.onnx

# Brain service URL
BRAIN_URL=http://localhost:3001

# Whisper model size: tiny | base | small
WHISPER_MODEL=base

# OpenWakeWord model
WAKE_WORD_MODEL=alexa

# Push-to-talk key
PTT_KEY=space

# Silence detection
SILENCE_DURATION=1.5
SILENCE_THRESHOLD=0.01
